config:
  sequence: {}
  theme: base
---
%%{init: {'flowchart': {'compactMode': true}}}%%
sequenceDiagram
    autonumber
    actor Campaign Moderator
    participant UI
    participant APIGateway as API Gateway
    participant BFF as Campaign BFF
    participant Orch as Campaign Launch <Br/>Orchestrator
    participant Participants as User Service
    participant Campaign as Campaign Service
    %%participant DB as PostgreSQL
    participant DB@{ "type": "database", "alias": "EPMS WBS schema"}
    participant Bus@{ "type": "queue", "alias": "Message Bus"}
    %%participant Bus as Kafka/Event Bus
    participant Notify as Notification Service
    participant Logger as Logger Service

    User->>UI: Click "Submit Campaign"
    UI->>APIGateway: Post Campaign {campaignId}
    APIGateway->>BFF: Forward request + JWT
    BFF->>Orch: orchestrateSubmission(campaignId, userId)

    Orch->>Campaign: Validate campaign state (DRAFT/READY)
    Campaign->>DB: Read campaign
    DB-->>Campaign: Campaign data
    Campaign-->>Orch: Validation result

    Orch->>Participants: Finalize participants (resolve DLs, dedupe)
    Participants-->>Orch: Participants Validated

    Orch->>Campaign: Submit campaign (status=SUBMITTED)
    Campaign->>DB: Update status 
    DB-->>Campaign: Status Updated
    Campaign->>Bus: Publish Campaign.Submitted
    Campaign-->>Orch: campaignId, campaignCode, status

    Bus-->>Notify: Consume Campaign.Submitted
    Notify->>Logger: Persist notification logs
    Notify-->>Bus: Notification sent

    Orch-->>BFF: Submission success payload
    BFF-->>APIGateway: 200 OK
    APIGateway-->>UI: Success response
    UI-->>User: "Campaign submitted successfully"
