sequenceDiagram
    actor User
    participant UI as React UI
    participant CDN as CDN
    participant Nginx as Nginx
    participant APIGateway as API Gateway
    participant AzureAD as Azure AD
    participant BFF as BFF Layer
    participant JO as Journey Orchestrator
    participant RE as Rules Engine
    participant MS1 as Business Microservice 1
    participant MS2 as Business Microservice 2
    participant Caching as Caching
    participant DB as Database
    participant IA as Integration Adapters
    participant EM as Event Messaging
    participant NS as Notification Service

    %% Initial Request Flow
    User->>UI: 1. Access Application
    UI->>CDN: 2. Request Static Assets
    CDN-->>UI: 3. Return Assets (JS, CSS, Images)
    
    %% Authentication Flow
    UI->>Nginx: 4. API Request
    Nginx->>APIGateway: 5. Forward Request
    APIGateway->>AzureAD: 6. Validate Token
    AzureAD-->>APIGateway: 7. Token Validated
    
    %% BFF Layer Processing
    APIGateway->>BFF: 8. Route to BFF
    BFF->>Caching: 9. Check Cache
    
    alt Cache Hit
        Caching-->>BFF: 10a. Return Cached Data
    else Cache Miss
        %% Journey Orchestration
        BFF->>JO: 10b. Orchestrate Journey
        JO->>RE: 11. Apply Business Rules
        RE-->>JO: 12. Rules Applied
        
        %% Microservices Processing
        par Parallel Microservice Calls
            JO->>MS1: 13a. Business Logic Request
            MS1->>DB: 14a. Query Data
            DB-->>MS1: 15a. Return Data
            MS1->>IA: 16a. External Integration
            IA-->>MS1: 17a. Integration Response
            MS1-->>JO: 18a. Service Response
        and
            JO->>MS2: 13b. Business Logic Request
            MS2->>DB: 14b. Query Data
            DB-->>MS2: 15b. Return Data
            MS2-->>JO: 18b. Service Response
        end
        
        %% Event & Notification Processing
        JO->>EM: 19. Publish Event
        EM->>NS: 20. Trigger Notification
        NS-->>User: 21. Send Notification (Email/SMS)
        
        %% Response and Caching
        JO-->>BFF: 22. Aggregated Response
        BFF->>Caching: 23. Update Cache
        Caching-->>BFF: 24. Cache Updated
    end
    
    %% Return Response to User
    BFF-->>APIGateway: 25. Response Data
    APIGateway-->>Nginx: 26. Forward Response
    Nginx-->>UI: 27. HTTP Response
    UI-->>User: 28. Display Result
    
    %% Background Processing
    Note over EM,NS: Asynchronous Event Processing
    EM->>MS1: 29. Event Consumed
    MS1->>DB: 30. Update State
    DB-->>MS1: 31. State Updated
    MS1->>EM: 32. Publish Result Event