sequenceDiagram
    autonumber
    actor User as User/Campaign Moderator
    participant UI
    participant APIGateway as API Gateway
    participant BFF as Campaign BFF
    participant Orch as Idea Submission Orchestrator
    participant Campaign as Campaign Service
    participant CampaignSchema as Campaign Schema PostgreSQL
    participant AIOrch as AI Orchestrator
    participant GenAI as AI Agent
    participant Idea as Idea Service
    participant IdeaSchema as Idea Schema PostgreSQL
    %% participant Adapter as Document Adapter
    %% participant Opentext as DocumentStore
    %% participant Cache as Caching

    Note over User : Idea Submission <Br/> Flow with AI Enhancement

    %% Step 1: User initiates idea creation
    %% User->>UI: Navigate to create idea
    %% UI->>APIGateway: Request campaigns for user
    %% APIGateway->>BFF: Forward request + JWT
    %% BFF->>Orch: Get eligible campaigns for user
    
    %% Step 2: Retrieve campaigns user is invited to
    %% Orch->>Campaign: Fetch user's invited campaigns
    %% Campaign->>CampaignSchema: Query campaigns by user invitation
    %% CampaignSchema-->>Campaign: Return campaign list
    %% Campaign-->>Orch: Campaign data
    %% Orch-->>BFF: Campaign list
    %% BFF-->>APIGateway: Campaign list JSON
    %% APIGateway-->>UI: Campaign list JSON
    %% UI-->>User: Display available campaigns
    
    %% Step 3: User selects campaign and creates idea
    User->>UI: Select campaign <Br/>and click "Create Idea"
    UI->>UI: Open idea creation form
    User->>UI: Fill idea details <Br/>(title, description, etc.)
    
    %% Step 4: AI Analysis - Auto or On-Demand
    Note over User,GenAI: AI Enhancement Flow
    
    alt User clicks "Ask AI/Auto AI Suggestion"
        User->>UI: Click "Ask AI" button
        UI->>APIGateway: POST /ai/analyze-idea <Br/>{description, title, context}
        APIGateway->>BFF: Forward AI request
        BFF->>AIOrch: analyzeIdeaContent(ideaData)
        AIOrch->>GenAI: Analyze idea description <Br/>and context
        GenAI->>GenAI: Process text, analyze quality, <Br/>generate suggestions
        GenAI-->>AIOrch: Return analysis <Br/>& enhancement suggestions
        AIOrch-->>BFF: AI response <Br/>{summary, suggestions, enhancedContent}
        BFF-->>APIGateway: AI analysis response
        APIGateway-->>UI: Display AI <Br/>suggestions
        UI-->>User: Show AI summary <Br/>and enhancement suggestions

   %% else Auto AI Analysis (on text entry)
   %%     User->>UI: Types/updates description
   %%     UI->>APIGateway: POST /ai/quick-analyze {description}
   %%     APIGateway->>BFF: Forward quick <Br/>analysis request
    %%    BFF->>AIOrch: quickAnalyzeContent(description)
    %%    AIOrch->>GenAI: Quick <Br/>analysis of text
    %%    GenAI-->>AIOrch: Brief <Br/>suggestions
    %%    AIOrch-->>BFF: Quick <Br/>suggestions
    %%    BFF-->>APIGateway: Suggestions response
    %%    APIGateway-->>UI: Display inline suggestions
    %%    UI-->>User: Show real-time AI hints
    end
    
    Note over User,GenAI: AI suggestions <Br/>help enhance idea quality
    
    %% Step 5: Load participants from cache
   %%  UI->>APIGateway: Request participant options
   %%  APIGateway->>BFF: Forward participant request
   %%  BFF->>Cache: Fetch cached participants
   %%  Cache-->>BFF: Return participant list
   %%  BFF-->>APIGateway: Participant list
   %%  APIGateway-->>UI: Participant list
   %%  UI-->>User: Display participants for selection
    
   %%  User->>UI: Select/modify participants
    
    %% Step 6: Document upload
   %%  User->>UI: Upload supporting documents
   %%  UI->>APIGateway: Upload document request
   %%  APIGateway->>BFF: Forward document upload
   %%  BFF->>Adapter: Store document
   %%  Adapter->>Opentext: Upload document to store
   %%  Opentext-->>Adapter: Document ID and metadata
   %%  Adapter-->>BFF: Document reference
   %%  BFF-->>APIGateway: Document upload success
   %%  APIGateway-->>UI: Document uploaded
   %%  UI-->>User: Document upload confirmation
    
    %% Step 7: Final AI Summary before submission (optional)
   %%  opt User requests final AI review
   %%      User->>UI: Click "Get Final AI Summary"
   %%      UI->>APIGateway: POST /ai/final-summary {completeIdeaData}
   %%      APIGateway->>BFF: Forward final summary request
   %%      BFF->>AIOrch: generateFinalSummary(ideaData)
   %%      AIOrch->>GenAI: Generate comprehensive summary
  %%       GenAI-->>AIOrch: Final summary with quality score
  %%       AIOrch-->>BFF: Summary and recommendations
  %%       BFF-->>APIGateway: Final AI summary
  %%       APIGateway-->>UI: Display final summary
  %%       UI-->>User: Show AI summary and quality score
  %%   end
    
    %% Step 8: Submit idea
    %%User->>UI: Submit idea against Campaign ID
    %% UI->>APIGateway: POST /ideas <Br/> {campaignId, ideaDetails, participants, documentRefs, aiMetadata}
    %% APIGateway->>BFF: Forward idea submission
    %% BFF->>Orch: orchestrateIdeaSubmission(campaignId, ideaData)
    
    %% Step 9: Store idea in database
    Orch->>Idea: Create idea record
     Idea->>IdeaSchema: Write idea data
    IdeaSchema-->>Idea: Idea created with ID
    
   %%  Idea->>IdeaSchema: INSERT idea participants
     IdeaSchema-->>Idea: Participants linked
    
   %%  Idea->>IdeaSchema: INSERT idea documents
   %% IdeaSchema-->>Idea: Documents linked
    
   %% Idea->>IdeaSchema: INSERT AI interaction metadata
   %% IdeaSchema-->>Idea: AI metadata stored
    
    Idea-->>Orch: Idea created successfully with ideaId
    Orch-->>BFF: Idea submission response
    BFF-->>APIGateway: Success response
    APIGateway-->>UI: Idea created successfully
    UI-->>User: "Idea submitted successfully"
    
    Note over IdeaSchema: All idea data including AI enhancements stored in PostgreSQL tables