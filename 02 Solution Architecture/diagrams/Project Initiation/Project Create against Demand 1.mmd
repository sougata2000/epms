%%{init: {'flowchart': {'compactMode': true}}}%%
sequenceDiagram
autonumber
actor BP as Business Partner
participant UI
participant APIG as API Gateway
participant IDAM as Azure AD / IDAM
participant BFF as Initiation BFF
%%participant PJO as Project Journey Orchestrator
participant ORCH@{ "type":"boundary", "alias":"Journey Orchestrator"}
participant DS as Request::Demand Service
participant PRS as Program Service
participant VCF as VCF Service<br/>(Program)
participant PS as Project Service
participant CACHE as Redis Cache
participant PRIMARY_DB@{ "type": "database", "alias": "EPMS schema"}
participant KAFKA@{ "type": "queue", "alias": "Message Bus"}

BP->>UI: Enter project details <br/>with Demand ID
UI->>APIG: POST /projects/initiate
APIG->>IDAM: Authenticate request
IDAM-->>APIG: Authentication success
APIG->>BFF: Forward request
BFF->>ORCH: Initiate project <br/>creation journey

ORCH->>DS: Validate Demand ID
DS->>CACHE: Check demand cache
alt Demand cache hit
    CACHE-->>DS: Demand details
else Demand cache miss
    DS->>PRIMARY_DB: Fetch demand
    PRIMARY_DB-->>DS: Demand details
    DS->>CACHE: Update demand cache
end
DS-->>ORCH: Demand valid

ORCH->>PRS: Find program by <br/>Demand ID / context
PRS->>PRIMARY_DB: Query program
alt Program exists
    PRIMARY_DB-->>PRS: Program details
    PRS-->>ORCH: Existing program found

    ORCH->>VCF: Fetch VCF for Program ID
    VCF->>PRIMARY_DB: Query VCF details
    PRIMARY_DB-->>VCF: VCF details
    VCF-->>ORCH: Existing VCF returned

    ORCH->>PS: Create project linked <br/>to Demand ID <br/>and Program ID
    PS->>PRIMARY_DB: Insert project in <br/>DRAFT/<br/>INITIATED state
    PRIMARY_DB-->>PS: Project ID generated
    PS-->>ORCH: Project created
else No program found
    PRIMARY_DB-->>PRS: No program found
    PRS-->>ORCH: Program not found

    ORCH->>PS: Create project in <br/>DRAFT without Program ID
    PS->>PRIMARY_DB: Insert draft project
    PRIMARY_DB-->>PS: Project ID generated
    PS-->>ORCH: Draft project created

    ORCH-->>BFF: Response with <br/>projectId + action<br/>=CREATE_PROGRAM
    BFF-->>APIG: Response
    APIG-->>UI: Open Program <br/>Creation Flow
end

ORCH->>KAFKA: Publish ProjectInitiated <br/>/ DraftCreated event
KAFKA-->>BFF: Async consumers continue